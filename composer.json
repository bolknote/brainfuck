{
    "name": "bolknote/brainfuck",
    "description": "Brainfuck to PHP compiler/transpiler with optimizer",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.4.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^13",
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.95",
        "rector/rector": "^2.4"
    },
    "autoload": {
        "psr-4": {
            "BolkNote\\Brainfuck\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BolkNote\\Brainfuck\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse --memory-limit=512M",
        "cs-fix": "php-cs-fixer fix --config=.php-cs-fixer.dist.php",
        "cs-check": "php-cs-fixer fix --dry-run --diff --config=.php-cs-fixer.dist.php",
        "rector": "rector process",
        "rector-check": "rector process --dry-run --no-progress-bar",
        "check": [
            "@phpstan",
            "@cs-check",
            "@rector-check",
            "@test"
        ]
    }
}
