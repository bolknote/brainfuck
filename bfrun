#!/usr/bin/env php
<?php

declare(strict_types=1);

error_reporting(E_ALL);
ini_set('display_errors', '1');

require __DIR__ . '/vendor/autoload.php';

use BolkNote\Brainfuck\Compiler;

function enableImmediateStdinMode(bool $enabled): ?string
{
    if (!$enabled || PHP_OS_FAMILY === 'Windows' || !function_exists('stream_isatty') || !stream_isatty(STDIN)) {
        return null;
    }

    $mode = [];
    exec('stty -g < /dev/tty 2>/dev/null', $mode, $status);
    if ($status !== 0 || !isset($mode[0]) || $mode[0] === '') {
        return null;
    }

    $unused = [];
    exec('stty raw -echo < /dev/tty 2>/dev/null', $unused, $status);
    if ($status !== 0) {
        return null;
    }

    return $mode[0];
}

function restoreImmediateStdinMode(?string $mode): void
{
    if ($mode === null) {
        return;
    }

    exec('stty ' . escapeshellarg($mode) . ' < /dev/tty 2>/dev/null');
}

function applyBfrunOption(
    string $arg,
    int &$cellBits,
    bool &$brainfork,
    bool &$debug,
    bool &$randomOpcode,
    bool &$inputCrLf,
    bool &$stdinLineBuffered,
): bool {
    if (preg_match('/^--bits=(\d+)$/', $arg, $m)) {
        $cellBits = (int) $m[1];

        return true;
    }

    if ($arg === '-Y' || $arg === '--fork' || $arg === '--brainfork') {
        $brainfork = true;

        return true;
    }

    if ($arg === '-d' || $arg === '--debug') {
        $debug = true;

        return true;
    }

    if ($arg === '--random' || $arg === '-@') {
        $randomOpcode = true;

        return true;
    }

    if ($arg === '--crlf-input' || $arg === '-W') {
        $inputCrLf = true;

        return true;
    }

    if ($arg === '--immediate-stdin' || $arg === '-I') {
        $stdinLineBuffered = false;

        return true;
    }

    return false;
}

/**
 * @return list<string>
 */
function extractHashbangOptions(string &$source): array
{
    if (!str_starts_with($source, '#!')) {
        return [];
    }

    $lineEnd = strpos($source, "\n");
    if ($lineEnd === false) {
        $hashbang = $source;
        $source = '';
    } else {
        $hashbang = substr($source, 0, $lineEnd);
        $source = substr($source, $lineEnd + 1);
    }

    $parts = preg_split('/\s+/', trim(substr($hashbang, 2)));
    if (!is_array($parts)) {
        return [];
    }

    $parts = array_values(array_filter($parts, static fn (string $part): bool => $part !== ''));
    foreach ($parts as $index => $part) {
        if (basename($part) === 'bfrun') {
            return array_slice($parts, $index + 1);
        }
    }

    return [];
}

$cellBits     = Compiler::DEFAULT_CELL_BITS;
$brainfork    = false;
$debug        = false;
$randomOpcode = false;
$inputCrLf       = false;
$stdinLineBuffered = true;
$args            = [];
$rawArgv   = $_SERVER['argv'] ?? null;
$cliArgv   = is_array($rawArgv) ? $rawArgv : [];
foreach (array_slice($cliArgv, 1) as $arg) {
    if (!is_string($arg)) {
        continue;
    }
    if (!applyBfrunOption($arg, $cellBits, $brainfork, $debug, $randomOpcode, $inputCrLf, $stdinLineBuffered)) {
        $args[] = $arg;
    }
}

if ($args === [] || $args[0] === '') {
    fwrite(STDERR, "Usage: bfrun [--bits=8|16|0] [-Y|--fork] [-d|--debug] [--random|-@] [--crlf-input|-W] [--immediate-stdin|-I] <file.bf>\n");
    exit(1);
}

$sourcePath = $args[0];
$source = file_get_contents($sourcePath);
if ($source === false) {
    fwrite(STDERR, "Error: cannot read file '{$sourcePath}'\n");
    exit(1);
}

foreach (extractHashbangOptions($source) as $arg) {
    if (!applyBfrunOption($arg, $cellBits, $brainfork, $debug, $randomOpcode, $inputCrLf, $stdinLineBuffered)) {
        fwrite(STDERR, "Error: unsupported hashbang option '{$arg}'\n");
        exit(1);
    }
}

$compiler = new Compiler(
    cellBits: $cellBits,
    brainfork: $brainfork,
    debug: $debug,
    randomOpcode: $randomOpcode,
    inputCrLf: $inputCrLf,
    stdinLineBuffered: $stdinLineBuffered,
);
$code = $compiler->compile($source);

$stdinMode = enableImmediateStdinMode(!$stdinLineBuffered);
try {
    eval($code);
} finally {
    restoreImmediateStdinMode($stdinMode);
}
