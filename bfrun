#!/usr/bin/env php
<?php

declare(strict_types=1);

error_reporting(E_ALL);
ini_set('display_errors', '1');
ini_set('memory_limit', '-1');

require __DIR__ . '/vendor/autoload.php';

use BolkNote\Brainfuck\Compiler;

/**
 * @return array{mode: string|null, blocking: bool|null}
 */
function enableImmediateStdinMode(bool $enabled): array
{
    if (!$enabled || PHP_OS_FAMILY === 'Windows' || !function_exists('stream_isatty') || !stream_isatty(STDIN)) {
        return ['mode' => null, 'blocking' => null];
    }

    $mode = [];
    exec('stty -g < /dev/tty 2>/dev/null', $mode, $status);
    if ($status !== 0 || !isset($mode[0]) || $mode[0] === '') {
        return ['mode' => null, 'blocking' => null];
    }

    $unused = [];
    exec('stty raw -echo < /dev/tty 2>/dev/null', $unused, $status);
    if ($status !== 0) {
        return ['mode' => null, 'blocking' => null];
    }

    $metadata = stream_get_meta_data(STDIN);
    $wasBlocking = $metadata['blocked'] === true;
    stream_set_blocking(STDIN, false);

    return ['mode' => $mode[0], 'blocking' => $wasBlocking];
}

/**
 * @param array{mode: string|null, blocking: bool|null} $state
 */
function restoreImmediateStdinMode(array $state): void
{
    if ($state['blocking'] !== null) {
        stream_set_blocking(STDIN, $state['blocking']);
    }

    if ($state['mode'] !== null) {
        exec('stty ' . escapeshellarg($state['mode']) . ' < /dev/tty 2>/dev/null');
    }
}

function memoryLimitToBytes(string $limit): int
{
    $limit = trim($limit);
    if ($limit === '' || $limit === '-1') {
        return -1;
    }

    $unit = strtolower($limit[strlen($limit) - 1]);
    $value = (int) $limit;

    return match ($unit) {
        'g' => $value * 1024 * 1024 * 1024,
        'm' => $value * 1024 * 1024,
        'k' => $value * 1024,
        default => $value,
    };
}

function ensureMemoryForLargeSource(string $source): void
{
    if (strlen($source) < 1024 * 1024) {
        return;
    }

    $current = memoryLimitToBytes((string) ini_get('memory_limit'));
    if ($current !== -1) {
        ini_set('memory_limit', '-1');
    }
}

function compiledCachePath(
    string $source,
    int $cellBits,
    bool $brainfork,
    bool $debug,
    bool $randomOpcode,
    bool $inputCrLf,
    bool $stdinLineBuffered,
): string {
    $compilerPath = __DIR__ . '/src/Compiler.php';
    $compilerHash = is_file($compilerPath) ? hash_file('sha256', $compilerPath) : '';
    $cacheKey = hash('sha256', implode("\n", [
        'bfrun-compiled-v1',
        hash('sha256', $source),
        $compilerHash !== false ? $compilerHash : '',
        (string) PHP_VERSION_ID,
        (string) $cellBits,
        $brainfork ? '1' : '0',
        $debug ? '1' : '0',
        $randomOpcode ? '1' : '0',
        $inputCrLf ? '1' : '0',
        $stdinLineBuffered ? '1' : '0',
    ]));

    return __DIR__ . '/var/cache/bfrun/' . $cacheKey . '.php';
}

function writeCompiledCache(string $path, string $code): void
{
    $dir = dirname($path);
    if (!is_dir($dir) && !mkdir($dir, 0777, true) && !is_dir($dir)) {
        return;
    }

    $tmp = $path . '.' . getmypid() . '.' . bin2hex(random_bytes(4)) . '.tmp';
    $bytes = file_put_contents($tmp, "<?php\n" . $code . "\n", LOCK_EX);
    if ($bytes === false) {
        return;
    }

    if (!rename($tmp, $path)) {
        @unlink($tmp);
    }
}

/**
 * @return callable|null
 */
function loadCompiledCache(string $path): ?callable
{
    if (!is_file($path)) {
        return null;
    }

    $fn = require $path;
    if (is_callable($fn)) {
        return $fn;
    }

    @unlink($path);

    return null;
}

function applyBfrunOption(
    string $arg,
    int &$cellBits,
    bool &$brainfork,
    bool &$debug,
    bool &$randomOpcode,
    bool &$inputCrLf,
    bool &$stdinLineBuffered,
    bool &$gzip,
): bool {
    if (preg_match('/^--bits=(\d+)$/', $arg, $m)) {
        $cellBits = (int) $m[1];

        return true;
    }

    $option = match ($arg) {
        '-Y', '--fork', '--brainfork' => 'brainfork',
        '-d', '--debug' => 'debug',
        '-@', '--random' => 'random',
        '-W', '--crlf-input' => 'crlf-input',
        '-I', '--immediate-stdin' => 'immediate-stdin',
        '-z', '--gzip' => 'gzip',
        default => null,
    };

    if ($option === null) {
        return false;
    }

    switch ($option) {
        case 'brainfork':
            $brainfork = true;
            break;
        case 'debug':
            $debug = true;
            break;
        case 'random':
            $randomOpcode = true;
            break;
        case 'crlf-input':
            $inputCrLf = true;
            break;
        case 'immediate-stdin':
            $stdinLineBuffered = false;
            break;
        case 'gzip':
            $gzip = true;
            break;
    }

    return true;
}

/**
 * @return list<string>
 */
function extractHashbangOptions(string &$source): array
{
    if (!str_starts_with($source, '#!')) {
        return [];
    }

    $lineEnd = strpos($source, "\n");
    if ($lineEnd === false) {
        $hashbang = $source;
        $source = '';
    } else {
        $hashbang = substr($source, 0, $lineEnd);
        $source = substr($source, $lineEnd + 1);
    }

    $parts = preg_split('/\s+/', trim(substr($hashbang, 2)));
    if (!is_array($parts)) {
        return [];
    }

    $parts = array_values(array_filter($parts, static fn (string $part): bool => $part !== ''));
    foreach ($parts as $index => $part) {
        if (basename($part) === 'bfrun') {
            return array_slice($parts, $index + 1);
        }
    }

    return [];
}

$cellBits     = Compiler::DEFAULT_CELL_BITS;
$brainfork    = false;
$debug        = false;
$randomOpcode = false;
$inputCrLf       = false;
$stdinLineBuffered = true;
$gzip            = false;
$args            = [];
$rawArgv   = $_SERVER['argv'] ?? null;
$cliArgv   = is_array($rawArgv) ? $rawArgv : [];
foreach (array_slice($cliArgv, 1) as $arg) {
    if (!is_string($arg)) {
        continue;
    }
    $arg = rtrim($arg, "\r");
    if (!applyBfrunOption($arg, $cellBits, $brainfork, $debug, $randomOpcode, $inputCrLf, $stdinLineBuffered, $gzip)) {
        $args[] = $arg;
    }
}

if ($args === [] || $args[0] === '') {
    fwrite(STDERR, "Usage: bfrun [--bits=8|16|0] [-Y|--fork] [-d|--debug] [--random|-@] [--crlf-input|-W] [--immediate-stdin|-I] [-z|--gzip] <file.bf>\n");
    exit(1);
}

$sourcePath = $args[0];
$source = file_get_contents($sourcePath);
if ($source === false) {
    fwrite(STDERR, "Error: cannot read file '{$sourcePath}'\n");
    exit(1);
}
ensureMemoryForLargeSource($source);

foreach (extractHashbangOptions($source) as $arg) {
    if (!applyBfrunOption($arg, $cellBits, $brainfork, $debug, $randomOpcode, $inputCrLf, $stdinLineBuffered, $gzip)) {
        fwrite(STDERR, "Error: unsupported hashbang option '{$arg}'\n");
        exit(1);
    }
}

if ($gzip) {
    $unpacked = @gzdecode($source);
    if ($unpacked === false) {
        fwrite(STDERR, "Error: cannot decode gzip source\n");
        exit(1);
    }
    $source = $unpacked;
}

$compiler = new Compiler(
    cellBits: $cellBits,
    brainfork: $brainfork,
    debug: $debug,
    randomOpcode: $randomOpcode,
    inputCrLf: $inputCrLf,
    stdinLineBuffered: $stdinLineBuffered,
);
$cachePath = compiledCachePath($source, $cellBits, $brainfork, $debug, $randomOpcode, $inputCrLf, $stdinLineBuffered);
$fn = loadCompiledCache($cachePath);
if ($fn === null) {
    $code = $compiler->compile($source);
    writeCompiledCache($cachePath, $code);
    $fn = loadCompiledCache($cachePath);
    if ($fn === null) {
        $fn = eval($code);
    }
}

$stdinMode = enableImmediateStdinMode(!$stdinLineBuffered);
try {
    if (!is_callable($fn)) {
        throw new \RuntimeException('Compiled code did not return a callable');
    }
    $fn();
} finally {
    if (!$stdinLineBuffered && function_exists('stream_isatty') && stream_isatty(STDERR)) {
        fwrite(STDERR, "\033[0m\033[?25h");
    }
    restoreImmediateStdinMode($stdinMode);
}
